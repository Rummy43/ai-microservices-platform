{
  "uid": "platform-jvm",
  "title": "Platform / JVM",
  "tags": ["platform", "jvm"],
  "timezone": "browser",
  "schemaVersion": 39,
  "refresh": "10s",
  "time": { "from": "now-1h", "to": "now" },
  "templating": {
    "list": [
      {
        "name": "service",
        "label": "Service",
        "type": "query",
        "datasource": { "type": "prometheus", "uid": "prometheus" },
        "query": "label_values(jvm_memory_used_bytes, job)",
        "refresh": 2,
        "includeAll": true,
        "multi": true,
        "current": { "text": "All", "value": "$__all" }
      }
    ]
  },
  "panels": [
    {
      "title": "Heap Used vs Max",
      "type": "timeseries",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 0 },
      "fieldConfig": { "defaults": { "unit": "bytes" }, "overrides": [] },
      "targets": [
        { "expr": "sum by (job) (jvm_memory_used_bytes{job=~\"$service\", area=\"heap\"})", "legendFormat": "{{job}} used" },
        { "expr": "sum by (job) (jvm_memory_max_bytes{job=~\"$service\", area=\"heap\"})", "legendFormat": "{{job}} max" }
      ]
    },
    {
      "title": "Heap Usage %",
      "type": "timeseries",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 0 },
      "fieldConfig": { "defaults": { "unit": "percentunit", "max": 1 }, "overrides": [] },
      "targets": [
        { "expr": "sum by (job) (jvm_memory_used_bytes{job=~\"$service\", area=\"heap\"}) / sum by (job) (jvm_memory_max_bytes{job=~\"$service\", area=\"heap\"})", "legendFormat": "{{job}}" }
      ]
    },
    {
      "title": "GC Pause Time (rate)",
      "type": "timeseries",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 8 },
      "fieldConfig": { "defaults": { "unit": "s" }, "overrides": [] },
      "targets": [
        { "expr": "sum by (job, action, cause) (rate(jvm_gc_pause_seconds_sum{job=~\"$service\"}[5m]))", "legendFormat": "{{job}} {{action}} ({{cause}})" }
      ]
    },
    {
      "title": "Max GC Pause",
      "type": "timeseries",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 8 },
      "fieldConfig": { "defaults": { "unit": "s" }, "overrides": [] },
      "targets": [
        { "expr": "max by (job) (jvm_gc_pause_seconds_max{job=~\"$service\"})", "legendFormat": "{{job}}" }
      ]
    },
    {
      "title": "Live Threads",
      "type": "timeseries",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 16 },
      "fieldConfig": { "defaults": { "unit": "short" }, "overrides": [] },
      "targets": [
        { "expr": "jvm_threads_live_threads{job=~\"$service\"}", "legendFormat": "{{job}} live" },
        { "expr": "jvm_threads_daemon_threads{job=~\"$service\"}", "legendFormat": "{{job}} daemon" },
        { "expr": "jvm_threads_peak_threads{job=~\"$service\"}", "legendFormat": "{{job}} peak" }
      ]
    },
    {
      "title": "Thread States",
      "type": "timeseries",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 16 },
      "fieldConfig": { "defaults": { "unit": "short" }, "overrides": [] },
      "targets": [
        { "expr": "sum by (job, state) (jvm_threads_states_threads{job=~\"$service\"})", "legendFormat": "{{job}} {{state}}" }
      ]
    },
    {
      "title": "Process CPU Usage",
      "type": "timeseries",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 24 },
      "fieldConfig": { "defaults": { "unit": "percentunit", "max": 1 }, "overrides": [] },
      "targets": [
        { "expr": "process_cpu_usage{job=~\"$service\"}", "legendFormat": "{{job}} process" },
        { "expr": "system_cpu_usage{job=~\"$service\"}", "legendFormat": "{{job}} system" }
      ]
    },
    {
      "title": "Loaded Classes",
      "type": "timeseries",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 24 },
      "fieldConfig": { "defaults": { "unit": "short" }, "overrides": [] },
      "targets": [
        { "expr": "jvm_classes_loaded_classes{job=~\"$service\"}", "legendFormat": "{{job}}" }
      ]
    }
  ]
}